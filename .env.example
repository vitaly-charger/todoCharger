APP_NAME="AI Inbox"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://todo.chargeragency.com.ua

LOG_CHANNEL=stack
LOG_LEVEL=info

# --- Database (MySQL in production) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ai_inbox
DB_USERNAME=ai_inbox
DB_PASSWORD=

# --- Cache / Session / Queue ---
CACHE_STORE=file
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

# --- Allow-list ---
ALLOWED_EMAIL=vitaly.vinnikov@gmail.com

# --- AI ---
AI_PROVIDER=claude
AI_MIN_CONFIDENCE=0.6
AI_STORE_RAW_BODY=true

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://todo.chargeragency.com.ua/auth/google/callback

# --- Sources ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=
MONDAY_API_TOKEN=
WRIKE_API_TOKEN=

# --- Sync intervals (minutes) ---
SYNC_GMAIL_MINUTES=5
SYNC_SLACK_MINUTES=5
SYNC_MONDAY_MINUTES=10
SYNC_WRIKE_MINUTES=10
SYNC_TELEGRAM_MINUTES=5

# --- Sanctum ---
SANCTUM_STATEFUL_DOMAINS=todo.chargeragency.com.ua
